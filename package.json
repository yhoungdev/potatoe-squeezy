{
  "name": "potato-monorepo",
  "version": "1.0.0",
  "license": "MIT",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "libs/*",
    "program"
  ],
  "scripts": {
    "dev:server": "cd apps/server && bun run dev",
    "dev:web": "cd apps/web-app && bun run dev",
    "build:web": "cd apps/web-app && bun run build",
    "start:server": "cd apps/server && bun run start",
    "format": "prettier --write ."
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
