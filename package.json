{
  "name": "potato-monorepo",
  "version": "1.0.0",
  "license": "MIT",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "bun --cwd apps/server dev & bun --cwd apps/web-app dev & bun --cwd apps/github-bot dev & bun --cwd apps/extension dev & wait",
    "start": "bun --cwd apps/server start & bun --cwd apps/web-app start & bun --cwd apps/github-bot start & bun --cwd apps/extension start & wait",
    "dev:server": "bun --cwd apps/server dev",
    "start:server": "bun --cwd apps/server start",
    "dev:web": "bun --cwd apps/web-app dev",
    "build:web": "bun --cwd apps/web-app build",
    "dev:bot": "bun --cwd apps/github-bot dev",
    "start:bot": "bun --cwd apps/github-bot start",
    "dev:extension": "bun --cwd apps/extension dev",
    "build:extension": "bun --cwd apps/extension build",
    "build": "bun --filter '*' run build",
    "format": "prettier --write ."
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
