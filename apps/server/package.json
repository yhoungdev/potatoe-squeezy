{
  "name": "@potatoe/server",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun run db:migrate && bun run --hot src/index.ts",
    "start": "bun run db:migrate && bun run src/index.ts",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run scripts/migrate.ts",
    "push": "bun run scripts/push-db.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "bun x drizzle-kit push",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@potatoe/db": "workspace:*",
    "@potatoe/shared": "workspace:*",
    "@hono-dev/auth-github": "^0.0.1",
    "@neondatabase/serverless": "^0.10.4",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.7.2",
    "pg": "^8.14.0",
    "prettier": "^3.5.3",
    "telegraf": "^4.16.3",
    "telegramify-markdown": "^1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.5",
    "typescript": "~5.8.3",
    "tsx": "^4.19.3"
  }
}
